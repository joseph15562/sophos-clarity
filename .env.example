# Sophos FireComply — Frontend Environment Variables
# Copy to .env and fill values from Supabase → Project Settings → API.
#
# These are the only variables needed for local development.
# Edge function secrets (GEMINI_API_KEY, RESEND_API_KEY, etc.) are configured
# separately via the Supabase Dashboard or `supabase secrets set`.

# Supabase project URL — https://<project-ref>.supabase.co
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase anon / public key (JWT with role "anon") — NOT the service_role secret.
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Optional: version string shown in report metadata and snapshots.
# VITE_APP_VERSION="1.0.0"

# Optional: connector package version treated as “latest” in Fleet / API hub (outdated filter).
# Agents report version via heartbeat `connector_version`; must match release tagging.
# VITE_CONNECTOR_VERSION_LATEST="1.0.0"

# Optional: HTTPS endpoint for JSON POST funnel events ({ event, props, ts, path }) from trackProductEvent.
# VITE_ANALYTICS_INGEST_URL="https://your-collector.example/ingest"

# Optional: Sentry browser DSN — omit to disable client error reporting (self-hosted friendly).
# VITE_SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"

# Loopback-only: synthesize signed-in workspace for Playwright without real credentials (never set on public deploy hostnames).
# VITE_E2E_AUTH_BYPASS="1"
