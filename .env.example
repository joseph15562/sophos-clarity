# Copy to .env.local and fill from Supabase → Project Settings → API.
# The project ref in VITE_SUPABASE_URL must match this project (same dashboard).

VITE_SUPABASE_PROJECT_ID="your-project-ref-id"
# Must be the anon / public key (JWT, role "anon") — NOT the service_role secret.
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-ref-id.supabase.co"
