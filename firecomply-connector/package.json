{
  "name": "firecomply-connector",
  "version": "1.6.11",
  "description": "FireComply Connector — Automated Sophos Firewall monitoring agent",
  "author": "FireComply <support@firecomply.io>",
  "homepage": "https://github.com/joseph15562/sophos-firecomply",
  "repository": {
    "type": "git",
    "url": "https://github.com/joseph15562/sophos-firecomply.git"
  },
  "private": true,
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsc -p tsconfig.main.json --watch\" \"electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "fast-xml-parser": "^4.5.1",
    "net-snmp": "^3.26.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/net-snmp": "^3.23.0",
    "@types/node": "^22.13.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "lucide-react": "^0.469.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sonner": "^1.7.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.14"
  }
}
