{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist/main",
    "rootDir": "src/main",
    "declaration": false
  },
  "include": ["src/main/**/*", "src/firewall/**/*", "src/analysis/**/*", "src/api/**/*", "src/scheduler.ts", "src/logger.ts", "src/config.ts"]
}
